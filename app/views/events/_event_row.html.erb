<%# ═══════════════════════════════════════════════════════════════
    app/views/events/_event_row.html.erb
    locals: event (Event)
    ═══════════════════════════════════════════════════════════════ %>

<%= link_to event_path(event),
      class: "event-row reveal",
      role: "listitem",
      "aria-label": "#{event.title} — #{event.event_date.strftime('%B %-d')}" do %>

  <div class="event-row__date" aria-label="<%= event.event_date.strftime('%B %-d') %>">
    <div class="event-row__date-day"><%= event.event_date.strftime('%-d') %></div>
    <div class="event-row__date-month"><%= event.event_date.strftime('%b').upcase %></div>
  </div>

  <div class="event-row__info">
    <div class="event-row__title"><%= event.title %></div>
    <div class="event-row__meta">
      <% if event.start_time %>
        <span><%= event.start_time.strftime('%-I:%M %p') %></span>
      <% end %>
      <% if event.location_name %>
        <span><%= event.location_name %><% if event.city %> · <%= event.city %><% end %></span>
      <% end %>
      <% if event.is_free %>
        <span>Free</span>
      <% end %>
    </div>
  </div>

  <span class="<%= event.type_badge_class %> event-badge">
    <%= event.event_type.humanize %>
  </span>
<% end %>