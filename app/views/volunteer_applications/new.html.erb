<%# ═══════════════════════════════════════════════════════════════
    app/views/volunteer_applications/new.html.erb
    ═══════════════════════════════════════════════════════════════ %>

<% content_for :title, "Volunteer" %>
<% content_for :meta_desc, "Join the YBNC volunteer team. Bring your skills — legal, design, media, organizing — in service of the community." %>

<section style="padding: 8rem 0 6rem; background: var(--black);">
  <div class="container" style="max-width: 760px;">
    <div class="mono-label reveal">Volunteer</div>
    <h1 style="font-family:'Syne',sans-serif;font-size:clamp(3rem,7vw,6rem);font-weight:900;text-transform:uppercase;letter-spacing:-.02em;color:var(--cream);line-height:.9;margin:var(--sp-3) 0 var(--sp-8);" class="reveal d1">
      Bring Your <span style="color:var(--red);">Skills.</span>
    </h1>

    <% if @application.errors.any? %>
      <div style="border:1px solid var(--red);padding:1rem 1.5rem;margin-bottom:2rem;font-size:.88rem;color:var(--red);font-family:'DM Mono',monospace;" role="alert">
        Please fix the following: <%= @application.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <%= form_with model: @application,
          url: volunteer_applications_path,
          class: "reveal d2",
          style: "display:flex;flex-direction:column;gap:1.25rem;" do |f| %>

      <div class="form-row">
        <div class="form-group">
          <%= f.label :first_name, "First Name", class: "form-label form-label--required" %>
          <%= f.text_field :first_name, class: "form-input", required: true, autocomplete: "given-name" %>
        </div>
        <div class="form-group">
          <%= f.label :last_name, "Last Name", class: "form-label form-label--required" %>
          <%= f.text_field :last_name, class: "form-input", required: true, autocomplete: "family-name" %>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <%= f.label :email, "Email", class: "form-label form-label--required" %>
          <%= f.email_field :email, class: "form-input", required: true, autocomplete: "email" %>
        </div>
        <div class="form-group">
          <%= f.label :phone, "Phone", class: "form-label" %>
          <%= f.tel_field :phone, class: "form-input", autocomplete: "tel" %>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <%= f.label :city, "City", class: "form-label" %>
          <%= f.text_field :city, class: "form-input" %>
        </div>
        <div class="form-group">
          <%= f.label :state, "State", class: "form-label" %>
          <%= f.text_field :state, class: "form-input" %>
        </div>
      </div>

      <div class="form-group">
        <%= f.label :skill_areas, "Where can you contribute?", class: "form-label" %>
        <div style="display:flex;flex-wrap:wrap;gap:.4rem;margin-top:.25rem;">
          <% VolunteerApplication::SKILL_AREAS.each do |skill| %>
            <label style="display:flex;align-items:center;gap:.4rem;padding:.35rem .75rem;border:1px solid var(--border);cursor:pointer;transition:all .2s;font-family:'DM Mono',monospace;font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;color:var(--text-muted);"
                   onmouseenter="this.style.borderColor='var(--gold)';this.style.color='var(--gold)'"
                   onmouseleave="if(!this.querySelector('input').checked){this.style.borderColor='var(--border)';this.style.color='var(--text-muted)'}">
              <%= check_box_tag "volunteer_application[skill_areas][]", skill, false,
                    style: "display:none;",
                    onchange: "this.parentElement.style.borderColor=this.checked?'var(--gold)':'var(--border)';this.parentElement.style.color=this.checked?'var(--gold)':'var(--text-muted)'" %>
              <%= skill.humanize.gsub("_", " ") %>
            </label>
          <% end %>
        </div>
      </div>

      <div class="form-group">
        <%= f.label :why_join, "Why do you want to join YBNC?", class: "form-label form-label--required" %>
        <%= f.text_area :why_join, class: "form-textarea form-input",
              placeholder: "Tell us what brings you here and what you're hoping to contribute.",
              required: true %>
      </div>

      <div class="form-group">
        <%= f.label :availability, "Your availability", class: "form-label" %>
        <%= f.select :availability,
              [["Weekends","weekends"],["Weekday evenings","weekday_evenings"],["Flexible","flexible"],["Event-by-event","as_needed"]],
              { include_blank: "Select…" }, class: "form-select form-input" %>
      </div>

      <%= f.submit "Submit Application →",
            class: "btn btn--red btn--lg btn--block",
            data: { disable_with: "Submitting..." } %>
    <% end %>
  </div>
</section>