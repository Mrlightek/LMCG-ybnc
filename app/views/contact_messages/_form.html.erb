<%# ═══════════════════════════════════════════════════════════════
    app/views/contact_messages/_form.html.erb
    ═══════════════════════════════════════════════════════════════ %>

<%= form_with model: @message || ContactMessage.new,
      url: contact_messages_path,
      class: "contact__form",
      style: "display:flex;flex-direction:column;gap:1.25rem;",
      data: { turbo: true } do |f| %>

  <div class="form-row">
    <div class="form-group">
      <%= f.label :name, "Your Name", class: "form-label form-label--required" %>
      <%= f.text_field :name, class: "form-input", required: true, autocomplete: "name" %>
    </div>
    <div class="form-group">
      <%= f.label :email, "Email", class: "form-label form-label--required" %>
      <%= f.email_field :email, class: "form-input", required: true, autocomplete: "email" %>
    </div>
  </div>

  <div class="form-group">
    <%= f.label :organization, "Organization (if applicable)", class: "form-label" %>
    <%= f.text_field :organization, class: "form-input", placeholder: "Media outlet, nonprofit, law firm..." %>
  </div>

  <div class="form-group">
    <%= f.label :inquiry_type, "Nature of Inquiry", class: "form-label" %>
    <%= f.select :inquiry_type,
          ContactMessage::INQUIRY_TYPES.map { |t| [t.humanize.gsub("_"," ").titleize, t] },
          { include_blank: "Select…" }, class: "form-select form-input" %>
  </div>

  <div class="form-group">
    <%= f.label :message, "Message", class: "form-label form-label--required" %>
    <%= f.text_area :message, class: "form-textarea form-input",
          placeholder: "Be specific about how you'd like to work together, what you need, or what you're offering.", required: true %>
  </div>

  <%= f.submit "Send Message →",
        class: "btn btn--red btn--lg btn--block",
        data: { disable_with: "Sending..." } %>

  <p class="form-hint" style="text-align:center;">
    We respond to all messages within 2–3 business days. For urgent matters, reach us on Instagram <a href="https://www.instagram.com/aestheticsconash/" target="_blank" style="color:var(--gold);">@aestheticsconash</a>.
  </p>
<% end %>
