<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>YBNC Dashboard — Young Black Nameless Coalition</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=Source+Serif+4:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════════════
   YBNC DASHBOARD — Design System (matches site exactly)
   Movement Editorial · Black Arts · Liberation Press
═══════════════════════════════════════════════════ */
:root {
  --black:      #0A0A0A;
  --charcoal:   #141414;
  --dark:       #1C1C1C;
  --dark-mid:   #262626;
  --border:     #2E2E2E;
  --border-lit: #3D3D3D;
  --red:        #B91C1C;
  --red-deep:   #991818;
  --red-glow:   rgba(185,28,28,0.12);
  --gold:       #C9A84C;
  --gold-lite:  #E0C278;
  --gold-mist:  rgba(201,168,76,0.1);
  --cream:      #F5F0E8;
  --cream-dark: #DDD5C4;
  --white:      #FAFAF8;
  --text-pri:   #F5F0E8;
  --text-sec:   #9A9488;
  --text-muted: #5C5650;
  --green:      #16A34A;
  --green-dim:  rgba(22,163,74,0.12);
  --blue:       #2563EB;
  --blue-dim:   rgba(37,99,235,0.10);
  --fd: 'Syne', sans-serif;
  --fb: 'Source Serif 4', Georgia, serif;
  --fm: 'DM Mono', monospace;
}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html,body{height:100%;overflow:hidden;}
body{font-family:var(--fd);background:var(--black);color:var(--text-pri);-webkit-font-smoothing:antialiased;font-size:14px;}

/* grain texture */
body::after{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='g'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23g)' opacity='0.03'/%3E%3C/svg%3E");pointer-events:none;z-index:9999;opacity:.4;}

::-webkit-scrollbar{width:3px;height:3px;}
::-webkit-scrollbar-track{background:var(--charcoal);}
::-webkit-scrollbar-thumb{background:var(--border-lit);}

/* ── SHELL ── */
.shell{display:grid;grid-template-columns:220px 1fr;grid-template-rows:52px 1fr;height:100vh;overflow:hidden;}

/* ── TOPBAR ── */
.topbar{
  grid-column:1/-1;
  background:var(--charcoal);
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;
  padding:0 1.5rem;gap:0;
  position:relative;z-index:100;
}
.tb-brand{display:flex;flex-direction:column;line-height:1;padding-right:1.5rem;border-right:1px solid var(--border);margin-right:1.25rem;}
.tb-abbr{font-family:var(--fd);font-size:1.1rem;font-weight:800;letter-spacing:.08em;color:var(--cream);}
.tb-full{font-family:var(--fm);font-size:.5rem;letter-spacing:.18em;text-transform:uppercase;color:var(--text-muted);margin-top:2px;}
.tb-stripe{width:3px;height:28px;background:var(--red);margin-right:1.25rem;flex-shrink:0;}

/* View toggle */
.view-toggle{display:flex;gap:0;border:1px solid var(--border);}
.vt-btn{
  font-family:var(--fd);font-size:.68rem;font-weight:700;
  letter-spacing:.12em;text-transform:uppercase;
  padding:.4rem 1.1rem;cursor:pointer;
  background:none;border:none;color:var(--text-sec);
  transition:all .15s;
}
.vt-btn.on{background:var(--red);color:var(--white);}
.vt-btn:not(.on):hover{color:var(--cream);background:var(--dark);}

/* Topbar right */
.tb-right{margin-left:auto;display:flex;align-items:center;gap:1rem;}
.tb-notif{position:relative;cursor:pointer;}
.tb-notif-icon{font-size:1rem;color:var(--text-sec);}
.tb-notif-badge{position:absolute;top:-4px;right:-6px;background:var(--red);color:#fff;font-family:var(--fm);font-size:.55rem;width:16px;height:16px;border-radius:50%;display:flex;align-items:center;justify-content:center;}
.tb-user{display:flex;align-items:center;gap:.6rem;cursor:pointer;}
.tb-avatar{width:30px;height:30px;background:var(--red);display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-size:.7rem;font-weight:800;color:#fff;letter-spacing:.04em;flex-shrink:0;}
.tb-user-name{font-family:var(--fd);font-size:.75rem;font-weight:700;color:var(--cream);letter-spacing:.06em;}
.tb-user-role{font-family:var(--fm);font-size:.55rem;letter-spacing:.14em;text-transform:uppercase;color:var(--text-muted);}

/* ── SIDEBAR ── */
.sidebar{
  background:var(--charcoal);
  border-right:1px solid var(--border);
  display:flex;flex-direction:column;
  overflow-y:auto;
  padding:1rem 0;
}

.nav-section{padding:0 .75rem;margin-bottom:1.25rem;}
.nav-section-label{
  font-family:var(--fm);font-size:.55rem;letter-spacing:.22em;
  text-transform:uppercase;color:var(--text-muted);
  padding:.3rem .5rem;margin-bottom:.3rem;
}
.nav-item{
  display:flex;align-items:center;gap:.65rem;
  padding:.55rem .75rem;
  font-family:var(--fd);font-size:.78rem;font-weight:600;
  letter-spacing:.06em;text-transform:uppercase;
  color:var(--text-sec);cursor:pointer;
  transition:all .15s;position:relative;
  border-left:2px solid transparent;
}
.nav-item:hover{color:var(--cream);background:var(--dark);}
.nav-item.on{
  color:var(--cream);background:var(--dark);
  border-left-color:var(--red);
}
.nav-icon{font-size:1rem;width:18px;text-align:center;flex-shrink:0;}
.nav-badge{
  margin-left:auto;font-family:var(--fm);font-size:.58rem;
  padding:1px 7px;background:var(--red-glow);
  border:1px solid rgba(185,28,28,.3);color:var(--red);
}
.nav-badge-gold{background:var(--gold-mist);border-color:rgba(201,168,76,.3);color:var(--gold);}

.sidebar-bottom{
  margin-top:auto;padding:.75rem 1rem 0;
  border-top:1px solid var(--border);
}
.sidebar-motto{
  font-family:var(--fb);font-style:italic;font-size:.75rem;
  color:var(--text-muted);line-height:1.5;
}
.sidebar-motto span{color:var(--gold);}

/* ── MAIN ── */
.main{overflow-y:auto;background:var(--black);}
.panel{display:none;padding:1.75rem 2rem;}
.panel.on{display:block;}

/* ── SHARED COMPONENTS ── */
.page-head{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:1.75rem;padding-bottom:1rem;border-bottom:1px solid var(--border);}
.page-head-left{}
.ph-label{font-family:var(--fm);font-size:.6rem;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);margin-bottom:.3rem;}
.ph-label::before{content:'▪ ';font-size:.5rem;}
.ph-title{font-family:var(--fd);font-size:1.6rem;font-weight:800;letter-spacing:-.01em;text-transform:uppercase;color:var(--cream);line-height:1;}
.ph-sub{font-family:var(--fb);font-size:.85rem;color:var(--text-sec);margin-top:.3rem;font-style:italic;}

/* Buttons */
.btn{
  font-family:var(--fd);font-size:.72rem;font-weight:700;
  letter-spacing:.1em;text-transform:uppercase;
  padding:.55rem 1.25rem;cursor:pointer;border:none;
  transition:all .15s;display:inline-flex;align-items:center;gap:.4rem;
}
.btn-sm{font-size:.65rem;padding:.4rem .9rem;}
.btn-red{background:var(--red);color:#fff;}
.btn-red:hover{background:var(--red-deep);}
.btn-gold{background:var(--gold);color:var(--black);}
.btn-gold:hover{background:var(--gold-lite);}
.btn-outline{background:transparent;color:var(--cream);border:1px solid var(--border-lit);}
.btn-outline:hover{border-color:var(--cream);}
.btn-ghost{background:var(--dark);color:var(--text-sec);border:1px solid var(--border);}
.btn-ghost:hover{color:var(--cream);}
.btn-danger{background:transparent;color:var(--red);border:1px solid rgba(185,28,28,.4);}
.btn-danger:hover{background:var(--red-glow);}

/* Metric cards */
.metrics{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--border);margin-bottom:1.5rem;border:1px solid var(--border);}
.metric{background:var(--charcoal);padding:1.25rem 1.5rem;position:relative;overflow:hidden;}
.metric::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
.m-red::before{background:var(--red);}
.m-gold::before{background:var(--gold);}
.m-green::before{background:var(--green);}
.m-cream::before{background:var(--cream-dark);}
.metric-label{font-family:var(--fm);font-size:.58rem;letter-spacing:.18em;text-transform:uppercase;color:var(--text-muted);margin-bottom:.4rem;}
.metric-val{font-family:var(--fd);font-size:2rem;font-weight:800;line-height:1;color:var(--cream);}
.metric-val.red{color:var(--red);}
.metric-val.gold{color:var(--gold);}
.metric-val.green{color:var(--green);}
.metric-sub{font-family:var(--fm);font-size:.6rem;color:var(--text-muted);margin-top:.3rem;}
.metric-delta{font-family:var(--fm);font-size:.62rem;margin-top:.2rem;}
.delta-up{color:var(--green);}
.delta-down{color:var(--red);}

/* Card */
.card{background:var(--dark);border:1px solid var(--border);padding:1.25rem 1.5rem;margin-bottom:1rem;}
.card-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;padding-bottom:.75rem;border-bottom:1px solid var(--border);}
.card-title{font-family:var(--fd);font-size:.8rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--cream);}
.card-title::before{content:'';display:inline-block;width:3px;height:12px;background:var(--red);margin-right:.5rem;vertical-align:middle;}

/* Table */
.tbl{width:100%;border-collapse:collapse;font-size:.82rem;}
.tbl th{
  text-align:left;padding:.5rem .75rem;
  font-family:var(--fm);font-size:.58rem;letter-spacing:.18em;text-transform:uppercase;
  color:var(--text-muted);border-bottom:1px solid var(--border);
}
.tbl td{padding:.7rem .75rem;border-bottom:1px solid var(--border);vertical-align:middle;}
.tbl tr:last-child td{border-bottom:none;}
.tbl tr:hover td{background:rgba(255,255,255,.02);}
.tbl-name{font-family:var(--fd);font-size:.8rem;font-weight:700;color:var(--cream);letter-spacing:.04em;}
.tbl-sub{font-family:var(--fm);font-size:.6rem;color:var(--text-muted);margin-top:1px;}

/* Status tags */
.tag{display:inline-flex;align-items:center;font-family:var(--fm);font-size:.58rem;letter-spacing:.1em;text-transform:uppercase;padding:2px 8px;}
.tag-active{background:var(--green-dim);border:1px solid rgba(22,163,74,.3);color:var(--green);}
.tag-pending{background:var(--gold-mist);border:1px solid rgba(201,168,76,.3);color:var(--gold);}
.tag-inactive{background:rgba(255,255,255,.04);border:1px solid var(--border);color:var(--text-muted);}
.tag-red{background:var(--red-glow);border:1px solid rgba(185,28,28,.3);color:var(--red);}
.tag-blue{background:var(--blue-dim);border:1px solid rgba(37,99,235,.3);color:#60A5FA;}

/* Progress bar */
.progress-track{width:100%;height:3px;background:var(--border);margin-top:.5rem;}
.progress-fill{height:100%;background:var(--red);transition:width .4s ease;}
.pf-gold{background:var(--gold);}
.pf-green{background:var(--green);}

/* Avatar initials */
.avatar{width:32px;height:32px;background:var(--dark-mid);border:1px solid var(--border-lit);display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-size:.65rem;font-weight:800;color:var(--cream);flex-shrink:0;letter-spacing:.04em;}
.avatar-red{background:var(--red-glow);border-color:rgba(185,28,28,.4);color:var(--red);}
.avatar-gold{background:var(--gold-mist);border-color:rgba(201,168,76,.4);color:var(--gold);}

/* Two-col grid */
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
.grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem;}

/* Form */
.form-row{margin-bottom:1rem;}
.form-row:last-child{margin-bottom:0;}
.f-label{display:block;font-family:var(--fm);font-size:.6rem;letter-spacing:.18em;text-transform:uppercase;color:var(--text-muted);margin-bottom:.4rem;}
.f-input{width:100%;background:var(--charcoal);border:1px solid var(--border);color:var(--cream);font-family:var(--fb);font-size:.88rem;padding:.6rem .85rem;outline:none;transition:border-color .15s;resize:vertical;}
.f-input:focus{border-color:var(--red);}
.f-input::placeholder{color:var(--text-muted);}
.f-select{width:100%;background:var(--charcoal);border:1px solid var(--border);color:var(--cream);font-family:var(--fb);font-size:.88rem;padding:.6rem .85rem;outline:none;appearance:none;cursor:pointer;}
.f-grid2{display:grid;grid-template-columns:1fr 1fr;gap:.75rem;}

/* Activity feed */
.activity-item{display:flex;gap:.85rem;padding:.75rem 0;border-bottom:1px solid var(--border);align-items:flex-start;}
.activity-item:last-child{border-bottom:none;}
.act-dot{width:8px;height:8px;flex-shrink:0;margin-top:5px;}
.ad-red{background:var(--red);}
.ad-gold{background:var(--gold);}
.ad-green{background:var(--green);}
.ad-gray{background:var(--border-lit);}
.act-text{font-family:var(--fb);font-size:.82rem;color:var(--text-sec);line-height:1.5;}
.act-text strong{color:var(--cream);font-weight:600;}
.act-time{font-family:var(--fm);font-size:.58rem;color:var(--text-muted);margin-top:.2rem;}

/* Toggle switch */
.toggle-row{display:flex;align-items:center;justify-content:space-between;padding:.6rem 0;border-bottom:1px solid var(--border);}
.toggle-row:last-child{border-bottom:none;}
.toggle-lbl{font-family:var(--fd);font-size:.78rem;font-weight:600;letter-spacing:.04em;color:var(--text-sec);}
.toggle-lbl small{display:block;font-family:var(--fb);font-size:.72rem;font-weight:400;color:var(--text-muted);margin-top:1px;letter-spacing:0;}
.tog{width:36px;height:18px;background:var(--border-lit);position:relative;cursor:pointer;flex-shrink:0;transition:background .2s;}
.tog.on{background:var(--red);}
.tog::after{content:'';position:absolute;top:2px;left:2px;width:14px;height:14px;background:var(--text-muted);transition:all .2s;}
.tog.on::after{left:20px;background:#fff;}

/* Stat mini */
.stat-mini-grid{display:grid;grid-template-columns:1fr 1fr;gap:.5rem;}
.stat-mini{background:var(--charcoal);border:1px solid var(--border);padding:.75rem;text-align:center;}
.sm-val{font-family:var(--fd);font-size:1.4rem;font-weight:800;color:var(--cream);}
.sm-val.red{color:var(--red);}
.sm-val.gold{color:var(--gold);}
.sm-lbl{font-family:var(--fm);font-size:.55rem;letter-spacing:.14em;text-transform:uppercase;color:var(--text-muted);margin-top:.2rem;}

/* Chart bars */
.chart-bars{display:flex;align-items:flex-end;gap:4px;height:72px;padding:0 2px;}
.bar-col{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;}
.bar{width:100%;background:var(--red);opacity:.7;transition:opacity .15s;cursor:default;}
.bar:hover{opacity:1;}
.bar-gold{background:var(--gold);}
.bar-lbl{font-family:var(--fm);font-size:.5rem;color:var(--text-muted);}

/* ═══════════════════════
   MEMBER VIEW SPECIFIC
═══════════════════════ */
.member-hero{
  background:var(--dark);border:1px solid var(--border);
  padding:1.75rem;margin-bottom:1.25rem;
  display:flex;align-items:center;gap:1.5rem;
  position:relative;overflow:hidden;
}
.member-hero::before{
  content:'YBNC';font-family:var(--fd);font-size:80px;font-weight:800;
  position:absolute;right:-10px;bottom:-15px;opacity:.03;letter-spacing:.1em;
  color:var(--cream);pointer-events:none;
}
.mh-avatar{width:60px;height:60px;background:var(--red);display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-size:1.3rem;font-weight:800;color:#fff;flex-shrink:0;}
.mh-name{font-family:var(--fd);font-size:1.4rem;font-weight:800;letter-spacing:-.01em;text-transform:uppercase;color:var(--cream);}
.mh-role{font-family:var(--fm);font-size:.58rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);margin-top:.2rem;}
.mh-since{font-family:var(--fb);font-style:italic;font-size:.82rem;color:var(--text-muted);margin-top:.2rem;}
.mh-stats{margin-left:auto;display:flex;gap:1.5rem;text-align:center;}
.mhs-val{font-family:var(--fd);font-size:1.2rem;font-weight:800;color:var(--cream);}
.mhs-lbl{font-family:var(--fm);font-size:.55rem;letter-spacing:.14em;text-transform:uppercase;color:var(--text-muted);margin-top:.1rem;}

/* Event card (member) */
.event-card{background:var(--dark);border:1px solid var(--border);padding:1.1rem 1.25rem;margin-bottom:.75rem;display:flex;gap:1rem;align-items:flex-start;transition:border-color .15s;cursor:default;}
.event-card:hover{border-color:var(--border-lit);}
.ec-date{background:var(--charcoal);border:1px solid var(--border);padding:.5rem .6rem;text-align:center;min-width:48px;flex-shrink:0;}
.ec-month{font-family:var(--fm);font-size:.55rem;letter-spacing:.12em;text-transform:uppercase;color:var(--gold);}
.ec-day{font-family:var(--fd);font-size:1.4rem;font-weight:800;color:var(--cream);line-height:1;}
.ec-title{font-family:var(--fd);font-size:.9rem;font-weight:700;letter-spacing:.04em;color:var(--cream);margin-bottom:.25rem;}
.ec-meta{font-family:var(--fm);font-size:.62rem;color:var(--text-muted);letter-spacing:.08em;}
.ec-actions{margin-left:auto;display:flex;flex-direction:column;gap:.35rem;align-items:flex-end;}

/* Skills card */
.skills-list{display:flex;flex-wrap:wrap;gap:.4rem;margin-top:.5rem;}
.skill-tag{background:var(--charcoal);border:1px solid var(--border);font-family:var(--fm);font-size:.6rem;letter-spacing:.1em;text-transform:uppercase;color:var(--text-sec);padding:3px 9px;}

/* ═══════════════════════════════════════════
   RED ACCENT LINE — decorative element from site
═══════════════════════════════════════════ */
.red-rule{width:3px;height:100%;background:var(--red);flex-shrink:0;}
.gold-rule{width:2px;background:var(--gold);flex-shrink:0;}

/* Horizontal red rule */
.hr-red{border:none;border-top:1px solid var(--border);position:relative;margin:1.25rem 0;}
.hr-red::before{content:'';position:absolute;top:-1px;left:0;width:48px;height:1px;background:var(--red);}

/* Announcement card */
.announce{background:var(--red-glow);border:1px solid rgba(185,28,28,.3);border-left:3px solid var(--red);padding:.9rem 1.1rem;margin-bottom:.75rem;}
.ann-head{font-family:var(--fd);font-size:.72rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--red);margin-bottom:.25rem;}
.ann-body{font-family:var(--fb);font-size:.85rem;color:var(--text-sec);line-height:1.55;}

/* ══ ROLE BADGE in topbar ══ */
.role-admin{color:var(--red);}
.role-member{color:var(--gold);}
</style>
</head>
<body>

<div class="shell">

<!-- ═══════════ TOPBAR ═══════════ -->
<header class="topbar">
  <div class="tb-brand">
    <div class="tb-abbr">YBNC</div>
    <div class="tb-full">Young Black Nameless Coalition</div>
  </div>
  <div class="tb-stripe"></div>

  <!-- View toggle: Admin / Member -->
  <div class="view-toggle">
    <button class="vt-btn on" onclick="setView('admin',this)">Admin View</button>
    <button class="vt-btn" onclick="setView('member',this)">Member View</button>
  </div>

  <div class="tb-right">
    <div class="tb-notif">
      <span class="tb-notif-icon">🔔</span>
      <span class="tb-notif-badge">5</span>
    </div>
    <div class="tb-user">
      <div class="tb-avatar" id="tbAvatar">AD</div>
      <div>
        <div class="tb-user-name" id="tbName">Ashley Dorelus</div>
        <div class="tb-user-role role-admin" id="tbRole">Admin · Founder</div>
      </div>
    </div>
  </div>
</header>

<!-- ═══════════ SIDEBAR ═══════════ -->
<nav class="sidebar" id="sidebar">
  <!-- Admin nav (shown by default) -->
  <div id="admin-nav">
    <div class="nav-section">
      <div class="nav-section-label">Command</div>
      <div class="nav-item on" onclick="goPanel('overview',this)">
        <span class="nav-icon">⬡</span> Overview
      </div>
      <div class="nav-item" onclick="goPanel('members',this)">
        <span class="nav-icon">✊</span> Members
        <span class="nav-badge">248</span>
      </div>
      <div class="nav-item" onclick="goPanel('events',this)">
        <span class="nav-icon">📅</span> Events
        <span class="nav-badge">3</span>
      </div>
      <div class="nav-item" onclick="goPanel('newsletter',this)">
        <span class="nav-icon">📬</span> Newsletter
        <span class="nav-badge nav-badge-gold">1.2K</span>
      </div>
    </div>
    <div class="nav-section">
      <div class="nav-section-label">Operations</div>
      <div class="nav-item" onclick="goPanel('donations',this)">
        <span class="nav-icon">💛</span> Donations
