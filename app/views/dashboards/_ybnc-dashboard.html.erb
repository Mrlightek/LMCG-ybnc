<script>
// ── PANEL SWITCHING ──────────────────────────────────
function goPanel(name, clickedItem) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('on'));
  const target = document.getElementById('panel-' + name);
  if (target) target.classList.add('on');

  document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('on'));
  if (clickedItem) clickedItem.classList.add('on');

  // scroll main to top
  document.querySelector('.main').scrollTop = 0;
}

// ── VIEW TOGGLE (Admin / Member) ─────────────────────
function setView(view, btn) {
  document.querySelectorAll('.vt-btn').forEach(b => b.classList.remove('on'));
  btn.classList.add('on');

  const adminNav  = document.getElementById('admin-nav');
  const memberNav = document.getElementById('member-nav');

  if (view === 'admin') {
    adminNav.style.display  = 'block';
    memberNav.style.display = 'none';
    // Reset avatar/role
    document.getElementById('tbAvatar').textContent     = 'AD';
    document.getElementById('tbName').textContent       = 'Ashley Dorelus';
    document.getElementById('tbRole').className         = 'tb-user-role role-admin';
    document.getElementById('tbRole').textContent       = 'Admin · Founder';
    // Show first admin panel
    goPanel('overview', adminNav.querySelector('.nav-item'));
  } else {
    adminNav.style.display  = 'none';
    memberNav.style.display = 'block';
    // Switch to member persona
    document.getElementById('tbAvatar').textContent     = 'KM';
    document.getElementById('tbName').textContent       = 'Keisha Morales';
    document.getElementById('tbRole').className         = 'tb-user-role role-member';
    document.getElementById('tbRole').textContent       = 'Member · Vallejo';
    // Show first member panel
    goPanel('m-home', memberNav.querySelector('.nav-item'));
  }
}

// Toggle switches (cosmetic)
document.querySelectorAll('.tog').forEach(t => {
  t.addEventListener('click', () => t.classList.toggle('on'));
});
</script>
